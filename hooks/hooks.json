{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/rqml-codex-hook.mjs session-start",
            "statusMessage": "Loading RQML status"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/rqml-codex-hook.mjs pre-tool-use",
            "statusMessage": "Checking the approval gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/rqml-codex-hook.mjs post-tool-use",
            "statusMessage": "Validating RQML spec edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/rqml-codex-hook.mjs stop",
            "statusMessage": "Running RQML check"
          }
        ]
      }
    ]
  }
}
